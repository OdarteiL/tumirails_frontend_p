{
  "info": {
    "name": "Tumi Configurator - Demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "tumi-demo-collection"
  },
  "item": [
    {
      "name": "Guest Flow",
      "item": [
        {
          "name": "G1 - Get Public Appliances",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/appliances?is_public=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "appliances"],
              "query": [{"key": "is_public", "value": "true"}]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j = pm.response.json();",
                  "if(j && Array.isArray(j.data) && j.data.length >= 2) {",
                  "  pm.environment.set('public_appliance_1', j.data[0].id);",
                  "  pm.environment.set('public_appliance_2', j.data[1].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "G2 - Guest Estimation (Public + Override)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appliances\": [\n    {\n      \"id\": {{public_appliance_1}},\n      \"quantity\": 2,\n      \"daily_usage_hours\": 6\n    },\n    {\n      \"id\": {{public_appliance_2}},\n      \"wattage\": 200,\n      \"quantity\": 1,\n      \"daily_usage_hours\": 8\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/estimations/guest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "estimations", "guest"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j = pm.response.json();",
                  "if(j && j.data && j.data.reference_code) {",
                  "  pm.environment.set('guest_estimation_ref', j.data.reference_code);",
                  "  pm.environment.set('guest_monthly_cost', j.data.estimated_monthly_cost);",
                  "  pm.test('estimation created', function() { pm.response.to.have.status(201); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "G3 - Fetch Guest Estimation by Reference",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/estimations/guest/{{guest_estimation_ref}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "estimations", "guest", "{{guest_estimation_ref}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('estimation retrieved', function() { pm.response.to.have.status(200); });",
                  "var j = pm.response.json();",
                  "pm.test('has reference code', function() { pm.expect(j.data.reference_code).to.eql(pm.environment.get('guest_estimation_ref')); });"
                ]
              }
            }
          ]
        },
        {
          "name": "G4 - Guest Reverse Estimation (Postpaid)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500,\n  \"payment_type\": \"postpaid\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/estimations/reverse/guest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "estimations", "reverse", "guest"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j = pm.response.json();",
                  "if(j && j.data && j.data.reference_code) {",
                  "  pm.environment.set('guest_reverse_postpaid_ref', j.data.reference_code);",
                  "  pm.test('reverse estimation created', function() { pm.response.to.have.status(201); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "G5 - Fetch Guest Reverse Postpaid",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/estimations/guest/{{guest_reverse_postpaid_ref}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "estimations", "guest", "{{guest_reverse_postpaid_ref}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('reverse estimation retrieved', function() { pm.response.to.have.status(200); });",
                  "var j = pm.response.json();",
                  "pm.test('has correct amount', function() { pm.expect(j.data.estimated_monthly_cost).to.eql(500); });"
                ]
              }
            }
          ]
        },
        {
          "name": "G6 - Guest Reverse Estimation (Prepaid)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 300,\n  \"payment_type\": \"prepaid\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/estimations/reverse/guest",
              "host": ["{{baseUrl}}"],
              "path": ["api", "estimations", "reverse", "guest"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var j = pm.response.json();",
                  "if(j && j.data && j.data.reference_code) {",
                  "  pm.environment.set('guest_reverse_prepaid_ref', j.data.reference_code);",
                  "  pm.test('reverse estimation created', function() { pm.response.to.have.status(201); });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "G7 - Fetch Guest Reverse Prepaid",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/estimations/guest/{{guest_reverse_prepaid_ref}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "estimations", "guest", "{{guest_reverse_prepaid_ref}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('reverse estimation retrieved', function() { pm.response.to.have.status(200); });",
                  "var j = pm.response.json();",
                  "pm.test('has correct amount', function() { pm.expect(j.data.estimated_monthly_cost).to.eql(300); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{demo_email}}\",\n  \"password\": \"{{demo_password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if(json && json.data && json.data.access_token) {",
              "  pm.environment.set('token', json.data.access_token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Create Site",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Demo Site\",\n  \"address\": \"45 Demo Street, Accra, Ghana\",\n  \"latitude\": 5.6037,\n  \"longitude\": -0.1870,\n  \"timezone\": \"Africa/Accra\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/sites", "host": ["{{baseUrl}}"], "path": ["api","sites"] }
      },
      "event": [
        { "listen": "test", "script": { "exec": [
          "var j = pm.response.json();",
          "if(j && j.data && j.data.id) pm.environment.set('site_id', j.data.id);",
          "else if(j && Array.isArray(j.data) && j.data.length) pm.environment.set('site_id', j.data[0].id);"
        ] } }
      ]
    },
    {
      "name": "03 - List Sites",
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/sites", "host": ["{{baseUrl}}"], "path": ["api","sites"] } }
    },
    {
      "name": "03.1 - List All Appliances",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/appliances", "host": ["{{baseUrl}}"], "path": ["api","appliances"] }
      }
    },
    {
      "name": "03.2 - List Site Appliances",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/sites/{{site_id}}/appliances", "host": ["{{baseUrl}}"], "path": ["api","sites","{{site_id}}","appliances"] }
      }
    },
    {
      "name": "03.3 - List Site Appliances (capture id)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/sites/{{site_id}}/appliances", "host": ["{{baseUrl}}"], "path": ["api","sites","{{site_id}}","appliances"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var j = pm.response.json();",
              "if(j && Array.isArray(j.data) && j.data.length) {",
              "  pm.environment.set('site_appliance_id', j.data[0].id);",
              "} else {",
              "  pm.environment.unset('site_appliance_id');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "03.4 - Remove Site Appliance",
      "request": {
        "method": "DELETE",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/sites/{{site_id}}/appliances/{{site_appliance_id}}", "host": ["{{baseUrl}}"], "path": ["api","sites","{{site_id}}","appliances","{{site_appliance_id}}"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('deleted successfully', function() { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Attach Appliance to Site",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"appliance_id\": {{appliance_id}},\n  \"quantity\": 1,\n  \"daily_usage_hours\": 6\n}" },
        "url": { "raw": "{{baseUrl}}/api/sites/{{site_id}}/appliances", "host": ["{{baseUrl}}"], "path": ["api","sites","{{site_id}}","appliances"] }
      }
    },
    {
      "name": "05 - Create Estimation",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"site_id\": {{site_id}}\n}" },
        "url": { "raw": "{{baseUrl}}/api/estimations", "host": ["{{baseUrl}}"], "path": ["api","estimations"] }
      },
      "event": [ { "listen": "test", "script": { "exec": [
        "var j = pm.response.json();",
        "if(j && j.data && j.data.id) pm.environment.set('estimation_id', j.data.id);"
      ] } } ]
    },
    {
      "name": "06 - Recalculate Estimation (PUT)",
      "request": {
        "method": "PUT",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/estimations/{{estimation_id}}", "host": ["{{baseUrl}}"], "path": ["api","estimations","{{estimation_id}}"] }
      }
    },
    {
      "name": "07 - Add another Appliance to Site",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"appliance_id\": {{appliance_id_2}},\n  \"quantity\": 1,\n  \"daily_usage_hours\": 8\n}" },
        "url": { "raw": "{{baseUrl}}/api/sites/{{site_id}}/appliances", "host": ["{{baseUrl}}"], "path": ["api","sites","{{site_id}}","appliances"] }
      }
    },
    {
      "name": "08 - Create Estimation (new version expected)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"site_id\": {{site_id}}\n}" },
        "url": { "raw": "{{baseUrl}}/api/estimations", "host": ["{{baseUrl}}"], "path": ["api","estimations"] }
      }
    },
    {
      "name": "09 - List Estimations",
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/estimations", "host": ["{{baseUrl}}"], "path": ["api","estimations"] } }
    },
    {
      "name": "10 - Get Recommendations",
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/estimations/{{estimation_id}}/recommendations", "host": ["{{baseUrl}}"], "path": ["api","estimations","{{estimation_id}}","recommendations"] } }
    }
    ,
    {
      "name": "11 - Persist Recommendation Bundle",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"total_cost\": 10000.00,\n  \"currency\": \"GHS\",\n  \"components\": [\n    { \"hardware_id\": {{hardware_id_1}}, \"quantity\": 1, \"total_cost\": 10000.00 }\n  ]\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/estimations/{{estimation_id}}/recommendations", "host": ["{{baseUrl}}"], "path": ["api","estimations","{{estimation_id}}","recommendations"] }
      },
      "event": [ { "listen": "test", "script": { "exec": [
        "var j = pm.response.json();",
        "if(j && j.data && j.data.id) { pm.environment.set('bundle_id', j.data.id); pm.test('bundle persisted', function() { pm.response.to.have.status(201); }); }"
      ] } } ]
    },
    {
      "name": "12 - Get Persisted Recommendation Bundles",
      "request": {
        "method": "GET",
        "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
        "url": { "raw": "{{baseUrl}}/api/estimations/{{estimation_id}}/recommendation-bundles", "host": ["{{baseUrl}}"], "path": ["api","estimations","{{estimation_id}}","recommendation-bundles"] }
      },
      "event": [ { "listen": "test", "script": { "exec": [
        "var j = pm.response.json();",
        "pm.test('ok', function() { pm.response.to.have.status(200); });",
        "if(j && Array.isArray(j.data) && j.data.length) { pm.environment.set('bundle_id', j.data[0].id); }"
      ] } } ]
    }
  ]
}
